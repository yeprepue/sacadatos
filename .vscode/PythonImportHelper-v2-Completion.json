    {
        "label": "GenerateReportUseCase",
        "kind": 6,
        "importPath": "src.application.use_cases.generate_report",
        "description": "src.application.use_cases.generate_report",
        "peekOfCode": "class GenerateReportUseCase:\n    def __init__(self, database: DatabasePort, drive_client: DriveClientPort):\n        self.db = database\n        self.drive = drive_client\n    def execute(self, local_path: str = \"/tmp/reporte_github.csv\") -> Dict:\n        summary = self.db.get_summary()\n        if not summary:\n            logger.warning(\"No hay datos para reportar\")\n            return {\"status\": \"no_data\"}\n        df = pd.DataFrame(summary)",
        "detail": "src.application.use_cases.generate_report",
        "documentation": {}
    },
    {
        "label": "setup_logging",
        "kind": 2,
        "importPath": "src.config.logging_config",
        "description": "src.config.logging_config",
        "peekOfCode": "def setup_logging():\n    \"\"\"Configura el logging para toda la app\"\"\"\n    logger.remove()\n    log_level = os.getenv(\"LOG_LEVEL\", \"INFO\")\n    # Console - desarrollo con colores\n    logger.add(\n        sys.stdout,\n        format=\"<green>{time:YYYY-MM-DD HH:mm:ss}</green> | <level>{level: <8}</level> | <cyan>{name}</cyan>:<cyan>{function}</cyan>:<cyan>{line}</cyan> - <level>{message}</level>\",\n        level=log_level,\n        colorize=True",
        "detail": "src.config.logging_config",
        "documentation": {}
    },
